---
import '../styles/typography.css';
import '../styles/global.css';
import '../styles/animations.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'Pento Luxury — Propiedades de Ultra-Lujo en Colombia',
  description = 'Residencias exclusivas en El Poblado, Llano Grande, El Retiro y Santa Marta. Curaduría de propiedades de alto patrimonio en Colombia.',
  image = '/og-image.jpg',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();

const realEstateAgentJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'RealEstateAgent',
  name: 'Pento Luxury',
  description,
  url: Astro.site?.toString(),
  areaServed: ['Medellín', 'El Poblado', 'Llano Grande', 'El Retiro', 'Envigado', 'Santa Marta', 'Colombia'],
  telephone: '+57 4 444 0000',
  email: 'asesores@pentoluxury.com',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Medellín',
    addressCountry: 'CO',
  },
};
---

<!doctype html>
<html lang="es-CO">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#080808" />
    <meta name="color-scheme" content="dark" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_CO" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site).toString()} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Pento Luxury" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site).toString()} />

    <!-- JSON-LD -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify(realEstateAgentJsonLd)}
    />
  </head>

  <body>
    <slot />
  </body>
</html>
