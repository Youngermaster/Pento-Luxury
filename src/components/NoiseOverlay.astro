---
// Photographic grain — fixed overlay across whole site.
---

<svg class="noise-overlay" aria-hidden="true">
  <filter id="pento-noise">
    <feTurbulence
      type="fractalNoise"
      baseFrequency="0.7"
      numOctaves="2"
      stitchTiles="stitch"
    />
    <feColorMatrix type="saturate" values="0" />
  </filter>
  <rect width="100%" height="100%" filter="url(#pento-noise)" />
</svg>

<style>
  .noise-overlay {
    position: fixed;
    inset: -50%;
    width: 200%;
    height: 200%;
    z-index: 9998;
    opacity: 0.035;
    pointer-events: none;
    mix-blend-mode: overlay;
    will-change: auto;
  }

  @media (prefers-reduced-motion: reduce) {
    .noise-overlay { opacity: 0.02; }
  }
</style>
