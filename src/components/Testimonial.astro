---
const bg =
  "https://images.unsplash.com/photo-1545324418-cc1a3fa10c00?w=2400&q=70&auto=format&fit=crop";
---

<section class="testimonial" aria-label="Testimonio cliente">
  <div
    class="testimonial__bg"
    style={`background-image:url(${bg})`}
    aria-hidden="true"
  >
  </div>
  <div class="testimonial__veil" aria-hidden="true"></div>

  <div class="testimonial__inner container">
    <span class="testimonial__quote-open" aria-hidden="true">“</span>
    <blockquote class="testimonial__text display" data-reveal>
      Pento no es una inmobiliaria.<br />
      Es el guardián del patrimonio familiar<br />
      que construí en treinta años.
    </blockquote>
    <footer class="testimonial__author">
      <span class="testimonial__rule" aria-hidden="true"></span>
      <p class="mono testimonial__author-name">Juan Camilo Álvarez</p>
      <p class="mono testimonial__author-role">Empresario · Medellín</p>
    </footer>
  </div>
</section>

<style>
  .testimonial {
    position: relative;
    isolation: isolate;
    padding: clamp(120px, 18vw, 220px) 0;
    overflow: hidden;
    background: var(--color-void);
  }

  .testimonial__bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    filter: blur(8px) saturate(0.7) brightness(0.45);
    transform: scale(1.1);
    z-index: -2;
  }

  .testimonial__veil {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        circle at 50% 50%,
        rgba(8, 8, 8, 0.4),
        rgba(8, 8, 8, 0.92)
      ),
      linear-gradient(180deg, rgba(8, 8, 8, 0.85), rgba(8, 8, 8, 0.85));
    z-index: -1;
  }

  .testimonial__inner {
    position: relative;
    text-align: center;
    max-width: 1000px;
  }

  .testimonial__quote-open {
    display: block;
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(140px, 18vw, 240px);
    line-height: 0.6;
    color: var(--color-gold-muted);
    opacity: 0.4;
    margin-bottom: -40px;
  }

  .testimonial__text {
    font-style: italic;
    font-weight: var(--weight-light);
    font-size: clamp(24px, 3.2vw, 44px);
    line-height: 1.4;
    color: var(--color-white);
    letter-spacing: -0.005em;
    max-width: 24ch;
    margin: 0 auto;
  }

  .testimonial__author {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    margin-top: clamp(60px, 8vw, 100px);
  }

  .testimonial__rule {
    width: 40px;
    height: 1px;
    background: var(--color-gold);
    display: block;
    margin-bottom: 14px;
  }

  .testimonial__author-name {
    font-size: 13px;
    letter-spacing: 0.3em;
    color: var(--color-white);
    text-transform: uppercase;
  }

  .testimonial__author-role {
    font-size: 11px;
    letter-spacing: 0.3em;
    color: var(--color-silver);
    text-transform: uppercase;
  }
</style>
