---
import Instagram from './icons/Instagram.astro';
import LinkedIn from './icons/LinkedIn.astro';

const cols = [
  {
    title: 'Propiedades',
    items: ['El Poblado', 'Llano Grande', 'Santa Marta'],
  },
  {
    title: 'Zonas',
    items: ['Envigado', 'El Retiro', 'Rionegro'],
  },
  {
    title: 'Historia',
    items: ['Equipo', 'Prensa', 'Filosofía'],
  },
];
---

<footer class="footer" role="contentinfo">
  <div class="container footer__inner">
    <div class="footer__brand">
      <h2 class="footer__logo display">
        PENTO <span aria-hidden="true">◆</span> LUXURY
      </h2>
      <p class="footer__address mono">
        Medellín, Colombia<br />
        Cra. 43A · El Poblado
      </p>
    </div>

    <nav class="footer__cols" aria-label="Pie de página">
      {cols.map((c) => (
        <div class="footer__col">
          <h3 class="label-mono footer__col-title">{c.title}</h3>
          <ul>
            {c.items.map((it) => (
              <li><a class="footer__col-link" href="#">{it}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </nav>
  </div>

  <hr class="footer__divider" />

  <div class="container footer__bottom">
    <p class="footer__copy mono">© 2026 Pento Luxury. Todos los derechos reservados.</p>
    <div class="footer__social" aria-label="Redes sociales">
      <a href="#" aria-label="Instagram"><Instagram size={16} /></a>
      <a href="#" aria-label="LinkedIn"><LinkedIn size={16} /></a>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-obsidian);
    color: var(--color-silver);
    padding-top: clamp(80px, 10vw, 140px);
    padding-bottom: clamp(28px, 3vw, 48px);
    border-top: var(--border-thin);
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1.2fr 2fr;
    gap: clamp(40px, 6vw, 100px);
    padding-bottom: clamp(56px, 8vw, 100px);
  }

  .footer__logo {
    font-size: clamp(28px, 3vw, 44px);
    font-weight: var(--weight-thin);
    letter-spacing: 0.18em;
    color: var(--color-white);
    margin-bottom: 24px;
    line-height: 1;
  }
  .footer__logo span { color: var(--color-gold); margin: 0 6px; }

  .footer__address {
    font-size: 11px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-dim);
    line-height: 1.8;
  }

  .footer__cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .footer__col-title {
    margin-bottom: 18px;
    color: var(--color-gold);
  }

  .footer__col ul { display: flex; flex-direction: column; gap: 10px; }

  .footer__col-link {
    color: var(--color-silver);
    font-size: 13px;
    transition: color 0.3s var(--ease-luxury);
  }
  .footer__col-link:hover { color: var(--color-gold); }

  .footer__divider {
    border: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-gold-muted), transparent);
    margin: 0;
  }

  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 28px;
    gap: 16px;
    flex-wrap: wrap;
  }

  .footer__copy {
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-dim);
  }

  .footer__social {
    display: inline-flex;
    gap: 14px;
  }
  .footer__social a {
    color: var(--color-silver);
    width: 34px; height: 34px;
    display: inline-grid; place-items: center;
    border: var(--border-thin);
    border-radius: var(--radius-card);
    transition: all 0.3s var(--ease-luxury);
  }
  .footer__social a:hover { color: var(--color-gold); border-color: var(--color-gold); }

  @media (max-width: 768px) {
    .footer__inner {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .footer__cols {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px 24px;
    }
  }
</style>
